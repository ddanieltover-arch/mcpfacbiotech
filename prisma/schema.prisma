// ──────────────────────────────────────────────────────────────────────────────
// MCPFAC BIOTECH — Prisma Schema Configuration
// Generator and datasource only. Models live in prisma/models/*.prisma
// ──────────────────────────────────────────────────────────────────────────────

generator client {
  provider      = "prisma-client-js"
  // native = local/CI; rhel-openssl-3.0.x = Vercel Node serverless
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
  previewFeatures = ["prismaSchemaFolder"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}
