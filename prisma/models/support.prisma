// ──────────────────────────────────────────────────────────────────────────────
// Support & Messaging Domain (Volume 5)
// Support tickets, conversations, messages
// ──────────────────────────────────────────────────────────────────────────────

enum TicketStatus {
  OPEN
  IN_PROGRESS
  PENDING_RESPONSE
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model SupportTicket {
  id         String         @id @default(uuid()) @db.Uuid
  createdAt  DateTime       @default(now()) @map("created_at")
  updatedAt  DateTime       @updatedAt @map("updated_at")
  ticketNumber String       @unique @map("ticket_number") @db.VarChar(50)
  customerId String         @map("customer_id") @db.Uuid
  assignedTo String?        @map("assigned_to") @db.Uuid
  subject    String         @db.VarChar(300)
  category   String         @db.VarChar(100)
  priority   TicketPriority @default(MEDIUM)
  status     TicketStatus   @default(OPEN)
  orderId    String?        @map("order_id") @db.Uuid

  customer       Customer          @relation(fields: [customerId], references: [id], onDelete: Restrict)
  messages       SupportMessage[]

  @@index([customerId])
  @@index([status])
  @@index([priority])
  @@index([createdAt])
  @@map("support_tickets")
}

model SupportMessage {
  id        String   @id @default(uuid()) @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")
  ticketId  String   @map("ticket_id") @db.Uuid
  senderId  String   @map("sender_id") @db.Uuid
  message   String   @db.Text
  isInternal Boolean @default(false) @map("is_internal") // staff-only notes

  ticket SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@map("support_messages")
}

// ─── Messaging ───────────────────────────────────────────────────────────────

model Conversation {
  id        String   @id @default(uuid()) @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  subject   String?  @db.VarChar(300)

  members  ConversationMember[]
  messages Message[]

  @@map("conversations")
}

model ConversationMember {
  id             String   @id @default(uuid()) @db.Uuid
  conversationId String   @map("conversation_id") @db.Uuid
  customerId     String   @map("customer_id") @db.Uuid
  lastReadAt     DateTime? @map("last_read_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  customer     Customer     @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@unique([conversationId, customerId])
  @@index([conversationId])
  @@index([customerId])
  @@map("conversation_members")
}

model Message {
  id             String   @id @default(uuid()) @db.Uuid
  createdAt      DateTime @default(now()) @map("created_at")
  conversationId String   @map("conversation_id") @db.Uuid
  senderId       String   @map("sender_id") @db.Uuid
  content        String   @db.Text

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([createdAt])
  @@map("messages")
}
