{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "installCommand": "cd ../.. && pnpm install --frozen-lockfile && pnpm db:generate",
  "buildCommand": "cd ../.. && pnpm --filter @mcpfac/shared-types build && pnpm --filter @mcpfac/api build",
  "rewrites": [{ "source": "/(.*)", "destination": "/api" }],
  "functions": {
    "api/index.ts": {
      "maxDuration": 60,
      "memory": 1024,
      "includeFiles": "{dist/**,../../node_modules/.prisma/**,../../node_modules/@prisma/client/**,../../node_modules/.pnpm/@prisma+client@*/**}"
    }
  }
}
