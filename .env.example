# ──────────────────────────────────────────────────────────────────────────────
# MCPFAC BIOTECH — Environment Variables
# Copy this file to .env and fill in the values for your environment.
# ──────────────────────────────────────────────────────────────────────────────

# ─── Application ──────────────────────────────────────────────────────────────
APP_URL=http://localhost:3000
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:3001
NODE_ENV=development

# ─── Supabase ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=

# ─── SMTP (Email) ─────────────────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
COMPANY_EMAIL=info@mcpfacbiotech.cn

# ─── Storage Buckets ──────────────────────────────────────────────────────────
STORAGE_BUCKET_PRODUCTS=products
STORAGE_BUCKET_DOCUMENTS=documents
STORAGE_BUCKET_COA=coa
STORAGE_BUCKET_MSDS=msds
STORAGE_BUCKET_HPLC=hplc
STORAGE_BUCKET_BLOG=blog
STORAGE_BUCKET_RESEARCH=research
STORAGE_BUCKET_INVOICES=invoices
STORAGE_BUCKET_AVATARS=avatars
STORAGE_BUCKET_BANNERS=banners
STORAGE_BUCKET_MEDIA=media
