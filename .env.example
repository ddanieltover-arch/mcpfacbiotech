# ──────────────────────────────────────────────────────────────────────────────
# MCPFAC BIOTECH — Environment Variables
# Copy this file to .env and fill in the values for your environment.
# ──────────────────────────────────────────────────────────────────────────────

# ─── Application ──────────────────────────────────────────────────────────────
# Production site: https://mcpfacbiotech.site — contact: info@mcpfacbiotech.site
APP_URL=http://localhost:3000
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:3001
NEXT_PUBLIC_BACKEND_URL=http://localhost:3001
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Production example (Vercel web + Vercel API + Supabase):
# APP_URL=https://mcpfacbiotech.site
# FRONTEND_URL=https://mcpfacbiotech.site
# NEXT_PUBLIC_APP_URL=https://mcpfacbiotech.site
# NEXT_PUBLIC_BACKEND_URL=https://api.mcpfacbiotech.site
#   (or the API project's *.vercel.app URL until the custom domain is attached)
NODE_ENV=development

# ─── Logging (API / Pino) ─────────────────────────────────────────────────────
# debug | info | warn | error — defaults: debug (dev), info (production)
LOG_LEVEL=debug

# ─── Deployment (see docs/DEPLOYMENT.md) ──────────────────────────────────────
# Web + API both on Vercel; database/auth/storage on Supabase.
# FRONTEND_URL on the API must match the live site (CORS).
# NEXT_PUBLIC_BACKEND_URL on the web must match the API Vercel origin.

# ─── Supabase ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=
DIRECT_URL=

# ─── Legacy Supabase Migration (old product database) ─────────────────────────
# Postgres connection string from the OLD Supabase project:
# Dashboard → Project Settings → Database → Connection string (URI)
SOURCE_DATABASE_URL=

# Optional overrides if legacy table names differ from defaults
# (defaults already match: categories, products, images, variants):
# LEGACY_TABLE_CATEGORIES=categories
# LEGACY_TABLE_PRODUCTS=products
# LEGACY_TABLE_IMAGES=images
# LEGACY_TABLE_VARIANTS=variants
# LEGACY_TABLE_DESCRIPTIONS=   (leave empty — descriptions live on products)

# Use file import (default) when you cannot access SOURCE_DATABASE_URL:
LEGACY_SOURCE_MODE=json

# Drop exports into prisma/migrate-legacy/data/:
#   categories.csv / categories_rows.csv
#   products.csv / products_rows.csv
#   images.csv / images_rows.csv
#   variants.csv / variants_rows.csv
#
# Do NOT import these CSVs via the Supabase Table Editor UI —
# our schema has required columns (updated_at, etc.) that legacy exports omit.
# Use: pnpm db:migrate-legacy

# Optional: remove sample M2 seed products before importing real catalog:
LEGACY_REPLACE_SAMPLE_PRODUCTS=true

# Promote a synced profile to ADMINISTRATOR:
#   PowerShell:  $env:ADMIN_EMAIL="you@example.com"; pnpm db:promote-admin
#   bash:        ADMIN_EMAIL=you@example.com pnpm db:promote-admin
# Admin API smoke (requires a REAL service_role key):
#   $env:ADMIN_EMAIL="you@example.com"; pnpm db:smoke-admin

# Auth E2E smoke (AUTH-9) — requires live Supabase + local dev stack:
#   pnpm install && pnpm exec playwright install chromium  (first time, from apps/web)
#   pnpm test:e2e
# Optional: PLAYWRIGHT_SKIP_WEBSERVER=1 if web+api already running via pnpm dev
# Optional: PLAYWRIGHT_BASE_URL=http://localhost:3000
# Optional: E2E_AUTH_CALLBACK_VERIFY=1 to also exercise /auth/callback via magic link
# Add http://localhost:3000/auth/callback to Supabase → Auth → URL configuration → Redirect URLs
#
# Commerce E2E (Phase 19) — catalog → cart → checkout guest flow:
#   Requires DATABASE_URL + seeded/imported catalog with priced products + pnpm dev

# ─── Resend (Email) ───────────────────────────────────────────────────────────
RESEND_API_KEY=
RESEND_FROM_EMAIL=info@mcpfacbiotech.site
RESEND_FROM_NAME=MCPFAC BIOTECH
COMPANY_EMAIL=info@mcpfacbiotech.site

# ─── Storage Buckets ──────────────────────────────────────────────────────────
STORAGE_BUCKET_PRODUCTS=products
STORAGE_BUCKET_DOCUMENTS=documents
STORAGE_BUCKET_COA=coa
STORAGE_BUCKET_MSDS=msds
STORAGE_BUCKET_HPLC=hplc
STORAGE_BUCKET_BLOG=blog
STORAGE_BUCKET_RESEARCH=research
STORAGE_BUCKET_INVOICES=invoices
STORAGE_BUCKET_AVATARS=avatars
STORAGE_BUCKET_BANNERS=banners
STORAGE_BUCKET_MEDIA=media
